{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/(app)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/layout.js"
    ],
    "/api/miniapps/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/miniapps/route.js"
    ],
    "/api/user/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/user/route.js"
    ],
    "/(app)/miniapps/marketplace/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/miniapps/marketplace/page.js"
    ],
    "/(app)/miniapps/run/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/miniapps/run/[id]/page.js"
    ],
    "/api/miniapps/[id]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/miniapps/[id]/route.js"
    ],
    "/(app)/miniapps/create/[[...id]]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(app)/miniapps/create/[[...id]]/page.css",
      "static/chunks/app/(app)/miniapps/create/[[...id]]/page.js"
    ]
  }
}